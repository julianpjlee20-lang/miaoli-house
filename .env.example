# ============================================
# 網域配置
# ============================================
# 你的網域 (例如: example.com)
DOMAIN=your-domain.com
# 是否啟用 HTTPS (true/false)
HTTPS=true
# HTTP/HTTPS 端口
HTTP_PORT=80
HTTPS_PORT=443

# ============================================
# API URL (不包含 http://)
# ============================================
# 完整的 API URL
API_URL=https://your-domain.com
POCKETBASE_URL=https://your-domain.com

# ============================================
# PocketBase 配置
# ============================================
# 生成一個隨機的密鑰: openssl rand -base64 32
POCKETBASE_SECRETS=change-this-to-random-string-generated-by-openssl
# 管理員帳號
PB_ADMIN_EMAIL=admin@your-domain.com
PB_ADMIN_PASSWORD=change-this-password

# ============================================
# MinIO 配置
# ============================================
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=presale-data

# ============================================
# 預設值 (開發用)
# ============================================
TZ=Asia/Taipei
